JDBC_DATABASE_URL=jdbc:postgresql://localhost:5432/scalora
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# Railway PostgreSQL can use these instead of JDBC_DATABASE_URL:
PGHOST=your-railway-host
PGPORT=5432
PGDATABASE=railway
PGUSER=postgres
PGPASSWORD=your-railway-password

JWT_SECRET=replace-with-a-strong-256-bit-secret-value
JWT_EXPIRATION_MINUTES=1440
CORS_ALLOWED_ORIGINS=http://localhost:5173
ADMIN_EMAIL=admin@scalora.com
ADMIN_PASSWORD=ChangeMe123!
